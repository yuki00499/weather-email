# 无锡天气邮件 - 环境变量配置
# 复制此文件为 .env 并填入真实信息

# QQ邮箱 SMTP 配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=2914642023@qq.com
SMTP_PASSWORD=你的SMTP授权码
SMTP_FROM=2914642023@qq.com
SMTP_FROM_NAME=天气助手

# 收件人
EMAIL_TO=2914642023@qq.com

# 邮件主题前缀
SUBJECT_PREFIX=[无锡天气]

# 发送时间 (北京时间)
SEND_HOUR=8
SEND_MINUTE=0
